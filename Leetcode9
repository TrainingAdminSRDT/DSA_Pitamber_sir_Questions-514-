class Leetcode9
{
    public boolean isPalindrome(int x) {
        int num=0,rev=0,sum=0;
        if(x<0)
        {
            return false;
        }
        int temp=x;
        while(x>0)
        {
            num=x%10;
            sum=sum*10+num;
            x=x/10;
        }
        return sum==temp;
    }
}
